{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a profile for a patient or a doctor.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["patient", "doctor"] },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "sharingEnabled": { "type": "boolean" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "bloodGroup": { "type": "string" },
        "address": { "type": "string" },
        "degree": { "type": "string" },
        "onboarded": { "type": "boolean" }
      },
      "required": ["role", "name", "email"]
    },
    "Record": {
      "title": "Medical Record",
      "description": "A prescription or report uploaded by a patient.",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "fileURL": { "type": "string" },
        "fileName": { "type": "string" },
        "type": { "type": "string", "enum": ["prescription", "report"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "fileURL", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profile information."
    },
    "/records/{recordId}": {
      "schema": "Record",
      "description": "Stores medical records links and metadata."
    }
  }
}
